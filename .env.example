# EnergyAI Environment Variables
# Copy this file to .env and fill in your real values:
#   cp .env.example .env

GROQ_API_KEY=your_groq_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_TTS_ENABLED=false
WATTTIME_USERNAME=your_watttime_username_here
WATTTIME_PASSWORD=your_watttime_password_here

# Optional overrides
# MODEL_PROFILE=cpu
# DEMO_MODE=false
# LLM_CHAT_MODEL=openai/gpt-oss-120b
# LLM_NARRATOR_MODEL=openai/gpt-oss-20b
# API_SECRET=your_api_secret_here
# CORS_ORIGINS=http://localhost:3000
